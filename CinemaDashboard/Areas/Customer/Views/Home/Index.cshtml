@model List<Movie>
@{ ViewData["Title"] = "Movies"; }
<header class="bg-dark py-5"><div class="container px-4 px-lg-5 my-5"><div class="text-center text-white"><h1 class="display-4 fw-bolder">Now Showing</h1><p class="lead fw-normal text-white-50 mb-0">Book your cinema tickets today</p></div></div></header>
<section class="py-3"><div class="container"><div class="row p-3 bg-light rounded"><form method="get" action="/Customer/Home/Index"><div class="row g-2">
<div class="col-md-3"><input type="text" class="form-control" placeholder="Movie Name" name="MovieName" value="@ViewBag.MovieName" /></div>
<div class="col-md-2"><input type="number" class="form-control" placeholder="Min Price" name="MinPrice" value="@ViewBag.MinPrice" /></div>
<div class="col-md-2"><input type="number" class="form-control" placeholder="Max Price" name="MaxPrice" value="@ViewBag.MaxPrice" /></div>
<div class="col-md-2"><select name="CategoryId" class="form-control"><option value="0">-- Category --</option>@foreach (var item in ViewBag.Categories){<option value="@item.Id" selected="@(item.Id == ViewBag.CategoryId)">@item.Name</option>}</select></div>
<div class="col-md-2"><select name="CinemaId" class="form-control"><option value="0">-- Cinema --</option>@foreach (var item in ViewBag.Cinemas){<option value="@item.Id" selected="@(item.Id == ViewBag.CinemaId)">@item.Name</option>}</select></div>
<div class="col-md-1 d-flex align-items-center"><input type="checkbox" class="form-check-input me-1" name="IsUpcoming" value="True" @(ViewBag.IsUpcoming != null ? "checked" : "") /><label>Upcoming</label></div>
</div><div class="row mt-2"><div class="col-md-2"><button class="btn btn-dark w-100">Filter</button></div><div class="col-md-2"><a href="/Customer/Home/Index" class="btn btn-outline-secondary w-100">Clear</a></div></div></form></div></div></section>
<section class="py-5"><div class="container px-4 px-lg-5 mt-3"><div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
@foreach (var item in Model) {
<div class="col mb-5"><div class="card h-100"><div class="badge bg-dark text-white position-absolute" style="top:.5rem;right:.5rem">@item.Category.Name</div><img class="card-img-top" src="~/images/@item.MainImg" alt="@item.Name" /><div class="card-body p-4"><div class="text-center"><h5 class="fw-bolder">@item.Name</h5><p class="text-muted small mb-1"><i class="bi bi-camera-reels"></i> @item.Cinema.Name</p><p class="text-muted small mb-2"><i class="bi bi-calendar-event"></i> @item.DateTime.ToString("dd MMM yyyy")</p><span class="fw-bold text-dark">EGP @item.Price</span></div></div><div class="card-footer p-4 pt-0 border-top-0 bg-transparent"><div class="text-center"><button class="btn btn-outline-dark mt-auto" data-bs-toggle="modal" data-bs-target="#bookModal" data-movie-id="@item.Id" data-movie-name="@item.Name" data-movie-price="@item.Price">Book Now</button></div></div></div></div>
}
</div></div>
<nav><ul class="pagination justify-content-center">@for(int i=1;i<=ViewBag.TotalPages;i++){<li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")"><a class="page-link" href="/Customer/Home/Index?Page=@i&MovieName=@ViewBag.MovieName&MinPrice=@ViewBag.MinPrice&MaxPrice=@ViewBag.MaxPrice&CategoryId=@ViewBag.CategoryId&CinemaId=@ViewBag.CinemaId">@i</a></li>}</ul></nav>
</section>
<div class="modal fade" id="bookModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Book Ticket</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><form method="post" action="/Customer/Home/Book"><div class="modal-body"><input type="hidden" name="MovieId" id="modalMovieId" /><p class="fw-bold" id="modalMovieName"></p><div class="mb-3"><label class="form-label">Your Name</label><input type="text" name="CustomerName" class="form-control" required /></div><div class="mb-3"><label class="form-label">Your Phone</label><input type="text" name="CustomerPhone" class="form-control" required /></div><div class="mb-3"><label class="form-label">Seats</label><input type="number" name="Seats" class="form-control" min="1" max="10" value="1" required /></div></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-dark">Confirm Booking</button></div></form></div></div></div>
@section Scripts { <script>document.addEventListener("DOMContentLoaded",function(){document.getElementById('bookModal').addEventListener('show.bs.modal',function(event){const b=event.relatedTarget;document.getElementById('modalMovieId').value=b.getAttribute('data-movie-id');document.getElementById('modalMovieName').textContent='🎬 '+b.getAttribute('data-movie-name')+' — EGP '+b.getAttribute('data-movie-price');});});</script>@if (TempData["Success-Notification"] is not null){<script>toastr.success('@TempData["Success-Notification"]')</script>} }

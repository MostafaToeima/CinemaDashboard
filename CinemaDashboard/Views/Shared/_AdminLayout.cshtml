<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Cinema Admin</title>
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,500,600,700|Poppins:300,400,500,600,700,800,900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">
    <link href="~/css/admin/styles.css" rel="stylesheet" />
</head>
<body>
    <main class="main" id="top">
        <div class="container-fluid">
            <div class="row min-vh-100">
                <nav class="col-12 col-lg-2 admin-sidebar p-3">
                    <a class="navbar-brand d-flex align-items-center mb-4" href="/Admin/Home/Index">
                        <span class="brand-icon me-2">🎬</span><span class="fw-bold fs-4">Cinema</span>
                    </a>
                    <div class="small text-uppercase text-muted mb-2">Dashboard</div>
                    <ul class="nav flex-column gap-1">
                        <li><a class="nav-link" href="/Admin/Home/Index"><i class="fa-solid fa-chart-pie me-2"></i>Home</a></li>
                        <li><a class="nav-link" href="/Admin/Category/Index"><i class="fa-solid fa-layer-group me-2"></i>Categories</a></li>
                        <li><a class="nav-link" href="/Admin/Cinema/Index"><i class="fa-solid fa-building me-2"></i>Cinemas</a></li>
                        <li><a class="nav-link" href="/Admin/Actor/Index"><i class="fa-solid fa-user-tie me-2"></i>Actors</a></li>
                        <li><a class="nav-link" href="/Admin/Movie/Index"><i class="fa-solid fa-film me-2"></i>Movies</a></li>
                    </ul>
                    <hr />
                    <a class="nav-link" href="/Customer/Home/Index"><i class="fa-solid fa-globe me-2"></i>Customer Area</a>
                </nav>
                <section class="col-12 col-lg-10 p-0">
                    <nav class="navbar navbar-light bg-white shadow-sm px-4">
                        <span class="fw-semibold">Cinema Dashboard</span>
                        <span class="badge bg-primary-subtle text-primary">Falcon style template</span>
                    </nav>
                    <div class="p-4">
                        @RenderBody()
                    </div>
                </section>
            </div>
        </div>
    </main>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://kit.fontawesome.com/4bb7a60e3b.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
